# Токен бота от @BotFather (обязательно)
BOT_TOKEN=

# ЕДИНСТВЕННЫЙ список тех, у кого есть власть над ботом и иммунитет от модерации.
# Только эти Telegram ID могут пользоваться командами и панелью. Статус «админ чата»
# НЕ даёт прав — админы-рекламщики в чате модерируются наравне со всеми. Через запятую.
# Свой ID узнать: команда /id в чате. 467308835 — админ по умолчанию.
ADMIN_IDS=467308835

# ID чата/канала, куда бот будет писать лог модерации (можно оставить пустым)
LOG_CHAT_ID=

# Путь к файлу базы данных (внутри контейнера)
DB_PATH=data/bot.db

# --- Флуд-контроль ---
FLOOD_MESSAGE_LIMIT=5
FLOOD_INTERVAL_SECONDS=10
FLOOD_MUTE_MINUTES=10

# После скольки предупреждений банить
WARN_LIMIT=3

# Сколько секунд ждать нажатия капчи новым участником, прежде чем кикнуть
CAPTCHA_TIMEOUT_SECONDS=120

# --- Анти-рейд (защита от массового вброса ботов) ---
# Если RAID_JOIN_LIMIT человек зашло за RAID_WINDOW_SECONDS секунд — включается локдаун:
# все новые участники сразу ограничиваются на RAID_LOCKDOWN_MINUTES минут, админам алерт.
RAID_JOIN_LIMIT=5
RAID_WINDOW_SECONDS=30
RAID_LOCKDOWN_MINUTES=10

# --- Лимит одинаковых сообщений (против повторной рекламы) ---
# Одинаковый текст от одного юзера разрешён DUPLICATE_LIMIT раз за DUPLICATE_WINDOW_HOURS часов,
# дальше копии удаляются. Короткие сообщения (< DUPLICATE_MIN_LENGTH символов) не учитываются.
DUPLICATE_LIMIT=3
DUPLICATE_WINDOW_HOURS=24
DUPLICATE_MIN_LENGTH=10

# Проверять пользователей по бан-листу CAS (Combot Anti-Spam, api.cas.chat)
CAS_CHECK_ENABLED=true

# Удалять сообщения со ссылками от не-админов
DELETE_LINKS=true

# "Мягкий" список: сообщение удаляется + предупреждение (бан после WARN_LIMIT).
# По умолчанию пуст — заполняется при желании в панели (/panel → Слова: предупреждение).
BANNED_WORDS=

# "Жёсткий" список: за любое из этих слов/фраз — МГНОВЕННЫЙ бан + удаление, без предупреждений.
# Сюда — наркошопы, рассылки, спам. Через запятую, без пробелов вокруг запятых.
BAN_WORDS=наркошоп,закладк,закладка,кладмен,клад мен,меф,мефедрон,амфетамин,скорость кристалл,гашиш,шишки,бошки,гидра,мяу мяу,соль кристалл,а29,работа курьер закладк,ищем курьеров,набор курьеров,приватная рассылка,массовая рассылка,спам рассылка,рассылка в лс,накрутка подписчиков,куплю аккаунты,продам базу,инвайтинг,срочно нужны,без опыта,от 14 до 45 лет,зарплата в месяц,нужны разнорабочие,хочешь монету,небольшая халтура,уборке склада,вознаграждение в адрес,поднять по быстрому денежку,срочно требуются сотрудники,ищем разнорабочих,оплата от,нужны ребята,достойная оплата,оплата труда,делов на часа 3,разобрали крышу,нужны рабочие,строительные отходы,взять деньжат,требуются разнорабочие,работа на стройке,помощь мастерам,простые физические задачи,график полный,оплата стабильная,выплата регулярно,желание работать,промывка ящиков,укладка упаковок,контроль качества,упаковка продукции,перекусы + чай,контроль площадки,выдача инвентаря,напитки + премии,сортировка грязной тары,чай + премии,делов на несколько часов,часов работы,достойная сумма,сумма уже на руках,уже на руках,всё объясняю по шагам

# Домены, ссылки на которые разрешены всем (через запятую), например ваш сайт
WHITELIST_DOMAINS=
